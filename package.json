{
  "name": "nft-mint-dapp-viem-wagmi",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "compile": "npx hardhat compile",
    "clean": "npx hardhat clean",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "predeploy": "npm run build && npm run lint && npm run type-check",
    "test": "npm run test:contract && npm run test:frontend",
    "test:contract": "npx hardhat test src/contracts/__tests__/*.test.ts",
    "test:frontend": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:components": "vitest run src/components",
    "test:hooks": "vitest run src/hooks",
    "test:services": "vitest run src/services",
    "typechain": "NODE_OPTIONS=\"--loader ts-node/esm --experimental-specifier-resolution=node\" hardhat typechain",
    "deploy:local": "npx hardhat run src/scripts/deploy.ts --network localhost",
    "deploy:sepolia": "npx hardhat run src/scripts/deploy.ts --network sepolia"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "erc721a": "^4.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "viem": "^2.46.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "ethers": "^6.16.0",
    "globals": "^16.5.0",
    "happy-dom": "^20.7.0",
    "hardhat": "^2.22.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
