# Your wallet private key (DO NOT COMMIT THIS TO GIT)
PRIVATE_KEY=

# Sepolia RPC URL (get from Infura/Alchemy)
SEPOLIA_RPC_URL=

VITE_CONTRACT_ADDRESS=
VITE_WALLET_CONNECT_PROJECT_ID=

# WebSocket disabled for dev - use polling fallback
VITE_USE_WEBSOCKET=

# Optional: Public HTTP RPC for polling
# Use these if VITE_USE_WEBSOCKET=false
VITE_RPC_URL_SEPOLIA=
VITE_RPC_URL_MAINNET=

# Optional: WebSocket URLs for real-time event listening (if using WebSockets)
# Use these if VITE_USE_WEBSOCKET=true
# VITE_ALCHEMY_WS_MAINNET=
VITE_ALCHEMY_WS_SEPOLIA=

# Optional: Alchemy API key for enhanced features (e.g., transaction history)
VITE_ALCHEMY_API_KEY=
VITE_ALCHEMY_NETWORK=

# Pinata IPFS Configuration (get from https://app.pinata.cloud)
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=